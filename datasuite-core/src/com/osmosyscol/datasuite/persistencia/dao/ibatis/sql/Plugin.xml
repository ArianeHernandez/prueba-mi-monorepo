<?xml version="1.0" encoding="ISO-8859-1" ?>

<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
    "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="Plugin">

	<typeAlias alias="plugin" type="com.osmosyscol.datasuite.logica.dto.Plugin" />
	
	<select id="obtenerPlugin" parameterClass="java.lang.String" resultClass="plugin">
		select * from dst_plugin
		where nombre = #nombre#
	</select>
	
	<select id="obtenerPlugins" resultClass="plugin">
		select * from dst_plugin
		order by orden
	</select>
	
	<select id="obtenerPluginsActivos" resultClass="plugin">
		select * from dst_plugin
		where activo = 'S'
		order by orden
	</select>
	
	<select id="obtenerPluginsPorAplicacion" parameterClass="java.lang.String" resultClass="plugin">
		select * from dst_plugin
		where id_aplicacion = #id_aplicacion#
		order by orden
	</select>

</sqlMap>