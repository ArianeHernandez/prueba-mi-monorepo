<?xml version="1.0" encoding="ISO-8859-1" ?>

<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
    "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="Configuracion">

	<typeAlias alias="registroConfiguracion"      type="com.osmosyscol.datasuite.logica.dto.RegistroConfiguracion" />
	
	<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

	<select id="obtenerRegistroConfiguracionByEtiqueta" resultClass="registroConfiguracion" parameterClass="java.lang.String">
		select * from dst_configuracion where etiqueta=#etiqueta#
	</select>
	
	<select id="obtenerRegistroConfiguracionByServicio" resultClass="registroConfiguracion" parameterClass="java.lang.String">
		select * from dst_configuracion where nombre_servicio=#servicio#
	</select>
	
	<select id="obtenerTodosRegistroConfiguracion" resultClass="registroConfiguracion">
		select * from dst_configuracion
	</select>
	
	
	
</sqlMap>
