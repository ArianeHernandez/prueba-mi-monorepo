<?xml version="1.0" encoding="ISO-8859-1" ?>

<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
    "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="Uri">

	<typeAlias alias="uri" type="com.osmosyscol.datasuite.modelatos.logica.dto.Uri" />

	<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->


	<select id="obtenerUri" resultClass="uri" parameterClass="java.lang.Integer">
		select * from dst_uri where id_uri = #id_uri#
	</select>
	
	<select id="obtenerTodasUri" resultClass="uri">
		select * from dst_uri
	</select>

	<select id="totalUris" resultClass="java.lang.Integer">
		select count(*)
		from (
			select * from dst_uri
		) DD
	</select>
	
	<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->
	<insert id="guardarUri" parameterClass="uri">
		insert into dst_uri (id_uri, nombre, endPoint) 
       		values (nextvalue('dss_uri'), #nombre#, #endPoint#) 
	</insert>
	
	<update id="actualizarUri" parameterClass="uri">
		update dst_uri set nombre = #nombre#, endPoint = #endPoint#
     	  where id_uri = #id_uri#
	</update>
	
	<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

	<delete id="eliminarUri" parameterClass="java.lang.Integer">
		delete from dst_uri where id_uri = #id_uri#
	</delete>
	
</sqlMap>
