<?xml version="1.0" encoding="ISO-8859-1" ?>

<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
    "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="Aplicacion">

	<typeAlias alias="aplicacion" type="com.osmosyscol.datasuite.logica.dto.Aplicacion" />
	
	<select id="obtenerAplicacion" parameterClass="java.lang.String" resultClass="aplicacion">
		select * from dst_aplicacion a
		where id_aplicacion = #id_aplicacion# 
	</select>
	
	
</sqlMap>
