<?xml version="1.0" encoding="ISO-8859-1" ?>

<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
    "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="AsignacionReporte">

	<typeAlias alias="AsignacionReporte"      type="com.osmosyscol.datasuite.reportedim.dto.AsignacionReporte" />
	
	<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

	<select id="obtenerAsignacionReporte" resultClass="AsignacionReporte" parameterClass="java.lang.Integer">
		select *
		from dst_rep_asignacion
		where id_asignacion=#id_asignacion#
	</select>
	
	<select id="obtenerAsignacionesReporte" resultClass="AsignacionReporte">
		select *
		from dst_rep_asignacion
	</select>
	
	<select id="obtenerAsignacionesReporteUsuario" resultClass="AsignacionReporte" parameterClass="java.lang.Integer">
		select *
		from dst_rep_asignacion
		where id_cliente = #id_usuario#
	</select>
	
	<select id="obtenerSiguienteAsignacionesReporteId" resultClass="java.lang.Integer">
		select nextvalue('dss_rep_asignacion') from dual
	</select>
	
	<select id="obtenerAsignacionesReporteRolTodos" resultClass="AsignacionReporte" parameterClass="java.lang.Integer">
		select *
		from dst_rep_asignacion
		where id_rol = #id_rol#
		and id_cliente is null
		and id_rol_auth is null
	</select>
	
	<select id="obtenerAsignacionReporteAdministrativo" resultClass="AsignacionReporte" parameterClass="java.lang.Integer">
		select *
		from dst_rep_asignacion
		where id_rol = 8
		and id_rol_auth is null
		or id_rol_auth = #id_rol_auth#
	</select>
	
	<select id="obtenerAsignacionReporteCliente" resultClass="AsignacionReporte" parameterClass="java.util.Map">
		select *
		from dst_rep_asignacion
		where id_rol = #id_rol#
		and id_rol_auth is null
		and id_cliente = #id_cliente#
	</select>
	
	<select id="totalAsignacionReportes" resultClass="java.lang.Integer" >
		select count(*) from dst_rep_asignacion
	</select>
	
	<insert id="crearAsignacionReporte" parameterClass="java.util.Map">
		insert into dst_rep_asignacion (id_asignacion, id_reporte, id_rol, titulo, activo, id_cliente, id_rol_auth)
		values (#id_asignacion#, #id_reporte#, #id_rol#, #titulo#, #activo#, #id_cliente#, #id_rol_auth#)
	</insert>
	
	<delete id="eliminarAsignacionReporte" parameterClass="java.lang.Integer">
		delete from dst_rep_asignacion
		where id_asignacion = #id_asignacion#
	</delete>	
		
	<update id="actualizarAsignacionReporte" parameterClass="AsignacionReporte">
		update dst_rep_asignacion set id_reporte = #id_reporte#, id_rol=#id_rol#, titulo=#titulo#, activo=#activo#,
		 id_cliente = #id_cliente#, id_rol_auth = #id_rol_auth#
		 where id_asignacion = #id_asignacion# 
	</update>
		
</sqlMap>
