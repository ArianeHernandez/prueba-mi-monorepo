<?xml version="1.0" encoding="ISO-8859-1"?>

<xsp:page language="java" 
	xmlns:cinclude="http://apache.org/cocoon/include/1.0" 
	xmlns:xsp="http://apache.org/xsp" 
	xmlns:xsp-request="http://apache.org/xsp/request/2.0" 
	xmlns:xsp-session="http://apache.org/xsp/session/2.0"
	xmlns:osm-utils="http://osmosyscol.com/logicsheets/osm-utils/1.0"
	xmlns:xscript="http://apache.org/xsp/xscript/1.0"
>
	
	<xsp:structure>
		<xsp:include>com.osmosyscol.datasuite.logica.constantes.Constantes</xsp:include>
	</xsp:structure>
	
    <OSM-ACCION>
    	<osm-utils:osm-session-request name="id_accion"/>
    	<osm-utils:osm-session-request name="id_formato_salida"/>
    	    	
    	<id_administrativo><xsp-session:get-attribute name="id_administrativo"/></id_administrativo>
    	<id_carga><xsp-session:get-attribute name="var.id_carga"/></id_carga>
    	<id_proceso_admin><xsp-session:get-attribute name="var.id_proceso_admin"/></id_proceso_admin>
    	<id_instancia><xsp-session:get-attribute name="var.id_instancia"/></id_instancia>
    	<id_accion_instancia><xsp-session:get-attribute name="var.id_accion"/></id_accion_instancia>
    	<id_formato_salida><xsp-session:get-attribute name="var.id_formato_salida"/></id_formato_salida>
    	
    	<!-- ACCION POR INSTANCIA -->
    	<cinclude:includexml>
    		<cinclude:src>cocoon:/webdata/proceso_admin/ejecutarAccionDeInstanciaActual.ser</cinclude:src>
            <cinclude:parameters>
                <cinclude:parameter>
                    <cinclude:name>id_accion</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_accion"/></cinclude:value>
                </cinclude:parameter>
                <cinclude:parameter> 	
                	<cinclude:name>id_carga</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_carga"/></cinclude:value>
                </cinclude:parameter>
                <cinclude:parameter>	
                	<cinclude:name>id_instancia_actual</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_instancia"/></cinclude:value>
                </cinclude:parameter>
                <cinclude:parameter>	
                	<cinclude:name>id_administrativo</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="id_administrativo"/></cinclude:value>
                </cinclude:parameter>
            </cinclude:parameters>
        </cinclude:includexml> 
    	
    	<!--NOTIFICACIONES POR INSTANCIA-->
    	<cinclude:includexml>
    		<cinclude:src>cocoon:/webdata/proceso_admin/enviarNotificacionesPorAccion.ser</cinclude:src>
        </cinclude:includexml> 
    	
    	
    	<cinclude:includexml>
    		<cinclude:src>cocoon:/webdata/formato/obtenerFormato.ser</cinclude:src>
            <cinclude:parameters>
                <cinclude:parameter>
                    <cinclude:name>id_formato</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_formato_salida"/></cinclude:value>
                </cinclude:parameter>
            </cinclude:parameters>
        </cinclude:includexml> 
    	
    	<cinclude:includexml>
    		<cinclude:src>cocoon:/webdata/carga/obtenerCarga.ser</cinclude:src>
            <cinclude:parameters>
                <cinclude:parameter>
                    <cinclude:name>id_carga</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_carga"/></cinclude:value>
                </cinclude:parameter>
            </cinclude:parameters>
        </cinclude:includexml>
    	
    </OSM-ACCION>
	
</xsp:page>