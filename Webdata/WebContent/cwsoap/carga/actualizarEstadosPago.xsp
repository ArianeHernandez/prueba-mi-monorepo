<?xml version="1.0" encoding="ISO-8859-1"?>

<xsp:page language="java"
          xmlns:xsp="http://apache.org/xsp"
          xmlns:xsp-request="http://apache.org/xsp/request/2.0"
		  xmlns:cinclude="http://apache.org/cocoon/include/1.0"
		  xmlns:xsp-session="http://apache.org/xsp/session/2.0"
	      xmlns:xscript="http://apache.org/xsp/xscript/1.0"
		  xmlns:soap="http://apache.org/xsp/soap/3.0"
>

<service>
	
	<soap:call>
        <soap:url><xsp:expr>"http://localhost:9081/ActualizacionEstadosService/ActualizacionEstadosPort"</xsp:expr></soap:url>
		<ps:eIdentificacionCarga xmlns:ps="http://xml.netbeans.org/schema/SynchronousSample">
			<ps:idCarga><xsp-request:get-parameter name="idCarga"/></ps:idCarga>
		</ps:eIdentificacionCarga>
    </soap:call>
</service>
	
</xsp:page>