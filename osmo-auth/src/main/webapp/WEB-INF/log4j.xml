<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">
<!-- purpose: Act as configuration template for applications. Application 
	should be using slf4j+log4j For compatibility, a special appender has been 
	created. -->
<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/"
	debug="true">

	<appender name="CONSOLE" class="org.apache.log4j.ConsoleAppender">
		<param name="Target" value="System.out" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern"
				value="%d{yyyy-MM-dd HH:mm:ss,SSS} [OSMOAUTENTICADOR] [%X{ip}-%X{host}] [%t] %n %5p %c{1}: %m%n" />
			<!-- The default pattern: Date Priority [Category] Message\n pattern1: 
				%d{yyyy-MM-dd HH:mm:ss,SSS} %-5p %t %c{6} \- %m%n pattern2: %d{yyyy-MM-dd HH:mm:ss,SSS} %-5p %t 
				%c - %m%n -->
		</layout>
	</appender>

	<appender name="SIMPLELOGGER"
		class="com.osmosyscol.commons.log.log4j.SimpleLoggerAdapterAppender">
		<layout class="org.apache.log4j.PatternLayout">
			<param name="applicationName" value="OSMOCORE" />
			<param name="ConversionPattern"
				value="%d{yyyy-MM-dd HH:mm:ss,SSS} [OSMOAUTENTICADOR] [%X{ip}-%X{host}] [%t] %n %5p %c{1} %m%n" />
		</layout>
	</appender>

	<appender name="ROLLINGFILE" class="org.apache.log4j.RollingFileAppender">
		<param name="file" value="logs/osmoautenticador.log" />
		<param name="MaxFileSize" value="10000KB" />
		<param name="MaxBackupIndex" value="100" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%n%d{yyyy-MM-dd HH:mm:ss,SSS} %5p [%t] %n %c: %m%n" />
		</layout>
	</appender>
	
	<!-- ####################### category interop :: datesuite, osmocore ############################# -->

	<category name="com.osmosyscol" additivity="false">
		<priority value="INFO" />
		<appender-ref ref="ROLLINGFILE" />
		<appender-ref ref="CONSOLE" />
	</category>

	<!-- ####################### category custom :: ########################## -->

	<!-- ####################### category root :: ########################## -->
	<root>
		<priority value="INFO" />
		<appender-ref ref="ROLLINGFILE" />
		<appender-ref ref="CONSOLE" />
	</root>

</log4j:configuration>
