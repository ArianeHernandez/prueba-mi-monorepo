<?xml version="1.0" encoding="ISO-8859-1" ?>

<!DOCTYPE sqlMap PUBLIC "-//ibatis.apache.org//DTD SQL Map 2.0//EN"
    "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="ProcesoPasante">

	<typeAlias alias="procesoPasante" type="com.osmosyscol.datasuite.mein.dtos.ProcesoPasante"/>
	
	<!-- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -->

	<select id="obtenerProcesoPasante" parameterClass="java.lang.Integer" resultClass="procesoPasante">
		select * from dst_proceso_pasante
			where id_formato = #id_formato#
	</select>
		
</sqlMap>
