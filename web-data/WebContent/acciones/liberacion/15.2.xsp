<?xml version="1.0" encoding="ISO-8859-1"?>

<xsp:page language="java" 
	xmlns:cinclude="http://apache.org/cocoon/include/1.0" 
	xmlns:xsp="http://apache.org/xsp" 
	xmlns:xsp-request="http://apache.org/xsp/request/2.0" 
	xmlns:xsp-session="http://apache.org/xsp/session/2.0"
	xmlns:osm-utils="http://osmosyscol.com/logicsheets/osm-utils/1.0"
>
    <OSM-ACCION>
    	
    	<osm-utils:remove-parameter name="_numeropagina" />
		
    	<osm-utils:osm-session-request name="_numeropagina" default="1"/>
    	<numeroPagina><xsp-session:get-attribute name="var._numeropagina"/></numeroPagina>
    	
    	<osm-utils:osm-session-request name="id_proceso"/>
    	<osm-utils:osm-session-request name="id_formato_salida"/>
    	
    	<proceso><xsp-request:get-parameter name="id_proceso"/></proceso>
    	<usuario><xsp-session:get-attribute name="id_usuario"/></usuario>
    	
    	<cinclude:includexml>
    		<cinclude:src>cocoon:/webdata/liberacion/obtenerCargasLiberacion.ser</cinclude:src>
            <cinclude:parameters> 
                <cinclude:parameter>
                    <cinclude:name>id_usuario</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="id_usuario"/></cinclude:value>
                </cinclude:parameter>
            	<cinclude:parameter>
                    <cinclude:name>estados</cinclude:name>
                    <cinclude:value>L</cinclude:value>
                </cinclude:parameter>
                <cinclude:parameter>
                    <cinclude:name>id_proceso</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_proceso"/></cinclude:value>
                </cinclude:parameter>
            	<cinclude:parameter>
                    <cinclude:name>pagina</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var._numeropagina"/></cinclude:value>
                </cinclude:parameter>
            </cinclude:parameters>
        </cinclude:includexml>
        
        <cinclude:includexml>
    		<cinclude:src>cocoon:/webdata/liberacion/contarCargasLiberacion.ser</cinclude:src>
            <cinclude:parameters> 
                <cinclude:parameter>
                    <cinclude:name>id_usuario</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="id_usuario"/></cinclude:value>
                </cinclude:parameter>
            	<cinclude:parameter>
                    <cinclude:name>estados</cinclude:name>
                    <cinclude:value>L</cinclude:value>
                </cinclude:parameter>
                <cinclude:parameter>
                    <cinclude:name>id_proceso</cinclude:name>
                    <cinclude:value><xsp-session:get-attribute name="var.id_proceso"/></cinclude:value>
                </cinclude:parameter>
            </cinclude:parameters>
        </cinclude:includexml>
        
        
    </OSM-ACCION>
	
</xsp:page>